<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Remover trailing slash
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [L,R=301]
    
    # Redirecionar requisições para index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?url=$1 [L,QSA]
</IfModule>

# Melhorar segurança
<Files "config/*">
    Order allow,deny
    Deny from all
</Files>

<Files "src/*">
    Order allow,deny
    Deny from all
</Files>
