# ========================================
# Exemplo de Arquivo de Configuração
# Copie este arquivo para cada ambiente
# ========================================

# Banco de Dados
DB_HOST=localhost
DB_USER=falai_user
DB_PASSWORD=sua_senha_segura
DB_NAME=falai_sa
DB_CHARSET=utf8mb4

# Aplicação
APP_NAME=Falaí
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo

# Segurança
SESSION_TIMEOUT=3600
PASSWORD_MIN_LENGTH=6

# Upload
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=png,jpg,jpeg,gif,bmp,webp
ALLOWED_DOCUMENT_TYPES=pdf,doc,docx,txt,zip
ALLOWED_VIDEO_TYPES=mp4,avi,mov,mkv

# Email (Futuro)
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# APIs Externas
# GOOGLE_MAPS_KEY=
# STRIPE_KEY=
